{
  "title": "bank-service - RED",
  "description": "Panel-as-code: request rate, error rate, and p95 latency for the accounts API. Import directly into Grafana or provision via the sidecar/ConfigMap pattern (see DECISIONS.md \"Observability\").",
  "schemaVersion": 39,
  "editable": true,
  "timezone": "utc",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "tags": ["bank-service", "red"],
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s by route)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{route=~\"/api/.*\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx / total, accounts API)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{route=\"/api/accounts/{id}\",status=\"Internal Server Error\"}[5m])) / sum(rate(http_requests_total{route=\"/api/accounts/{id}\"}[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 latency, GET /api/accounts/{id}",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{route=\"/api/accounts/{id}\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  }
}
